    "brain": {
      "start": "hunt",
      "states": {
        "hunt": {
          "tracks": [
            {
              "id": "move",
              "loop": true,
              "steps": [
                {
                  "moveTo": {
                    "target": "arena.randomAir",
                    "speed": 2.5
                  }
                },
                {
                  "wait": {
                    "range": [
                      0.4,
                      0.8
                    ]
                  }
                }
              ]
            },
            {
              "id": "attack",
              "loop": true,
              "steps": [
                {
                  "telegraph": {
                    "part": "left_wing",
                    "time": 0.45
                  }
                },
                {
                  "fire": {
                    "emitter": "left_wing.missiles",
                    "count": 2,
                    "pattern": "fan",
                    "spread": 22
                  }
                },
                {
                  "fire": {
                    "emitter": "right_wing.missiles",
                    "count": 2,
                    "pattern": "fan",
                    "spread": 22
                  }
                },
                {
                  "wait": 2.0
                }
              ]
            }
          ],
          "transitions": [
            {
              "when": "self.hpPct <= 0.5",
              "to": "rage"
            }
          ]
        },
        "rage": {
          "tracks": [
            {
              "id": "rage_move",
              "loop": true,
              "steps": [
                {
                  "dash": {
                    "target": "player",
                    "speed": 6,
                    "duration": 0.5
                  }
                },
                {
                  "wait": 0.65
                }
              ]
            },
            {
              "id": "rage_attack",
              "loop": true,
              "steps": [
                {
                  "fire": {
                    "emitter": "left_wing.missiles",
                    "count": 3,
                    "pattern": "fan",
                    "spread": 35
                  }
                },
                {
                  "fire": {
                    "emitter": "right_wing.missiles",
                    "count": 3,
                    "pattern": "fan",
                    "spread": 35
                  }
                },
                {
                  "wait": 1.2
                }
              ]
            }
          ]
        }
