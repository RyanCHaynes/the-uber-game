        {
          "id": "right_wing",
          "tags": [
            "bossPart",
            "wing"
          ],
          "at": [
            1.7,
            0
          ],
          "visual": {
            "shape": "diamond",
            "size": [
              1.8,
              0.8
            ],
            "tint": "#ffb454"
          },
          "body": {
            "shape": "box",
            "size": [
              1.6,
              0.7
            ],
            "gravity": 0
          },
          "health": {
            "max": 20
          },
          "emitters": {
            "missiles": {
              "at": [
                0.5,
                0
              ],
              "ref": "seeker",
              "pattern": "fan"
            }
          },
          "on": {
            "destroy": [
              {
                "signal": {
                  "name": "wingDestroyed"
                }
              }
            ]
          }
